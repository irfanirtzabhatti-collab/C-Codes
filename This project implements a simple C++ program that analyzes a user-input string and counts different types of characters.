#include <iostream>
using namespace std;

int main()
{
    string str;
    cout << "Enter text (press Enter to finish):\n";
    
    getline(cin, str);

    int chars = 0, spaces = 0, tabs = 0, lines = 1;

    for (int i = 0; i < str.length(); i++)
    {
        chars++;

        if (str[i] == ' ')
            spaces++;
        else if (str[i] == '\t')
            tabs++;
        else if (str[i] == '\n')
            lines++;
    }

    cout << "\nCharacters: " << chars;
    cout << "\nSpaces: " << spaces;
    cout << "\nTabs: " << tabs;
    cout << "\nLines: " << lines;
}
