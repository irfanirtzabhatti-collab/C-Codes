#include <iostream>
using namespace std;

double mean(int a[], int n){
    int s=0; for(int i=0;i<n;i++) s+=a[i];
    return (double)s/n;
}

double median(int a[], int n){
    return (n%2)? a[n/2] : (a[n/2]+a[n/2-1])/2.0;
}

int mode(int a[], int n){
    int m=a[0], mc=0;
    for(int i=0;i<n;i++){
        int c=0;
        for(int j=0;j<n;j++) if(a[i]==a[j]) c++;
        if(c>mc){ mc=c; m=a[i]; }
    }
    return m;
}

int main(){
    int a[]={1,2,2,3,4}, n=5;

    // simple sort
    for(int i=0;i<n;i++)
        for(int j=i+1;j<n;j++)
            if(a[i]>a[j]) swap(a[i],a[j]);

    cout<<"Mean="<<mean(a,n);
    cout<<"\nMedian="<<median(a,n);
    cout<<"\nMode="<<mode(a,n);
}
